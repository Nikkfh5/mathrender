{
  "name": "mathrender",
  "displayName": "MathRender — LaTeX Formula Renderer for Claude Code",
  "description": "Renders LaTeX formulas from Claude Code responses in a beautiful VS Code side panel with KaTeX. See math as it's meant to be seen.",
  "version": "0.2.0",
  "publisher": "Nikkfh5",
  "author": {
    "name": "Nikkfh5",
    "email": "v-353@yandex.com"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nikkfh5/mathrender"
  },
  "bugs": {
    "url": "https://github.com/Nikkfh5/mathrender/issues"
  },
  "homepage": "https://github.com/Nikkfh5/mathrender#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "latex",
    "math",
    "formula",
    "katex",
    "claude",
    "claude-code",
    "render",
    "markdown"
  ],
  "galleryBanner": {
    "color": "#0a0a0f",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "mathrender.show",
        "title": "Show Panel",
        "category": "MathRender"
      },
      {
        "command": "mathrender.on",
        "title": "Enable",
        "category": "MathRender"
      },
      {
        "command": "mathrender.off",
        "title": "Disable",
        "category": "MathRender"
      },
      {
        "command": "mathrender.setupHook",
        "title": "Setup Hook",
        "category": "MathRender"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
